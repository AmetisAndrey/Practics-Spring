{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "http://example.com/crudapp/Item.json",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid"
    },
    "name":{
      "type": "string",
      "minLength": 3,
      "maxLength": 50
    },
    "description": {
      "type": "string",
      "maxLength": 255
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
    "type": "string",
      "format": "date-time"
}
  },
  "required": ["name"]
}